# ============================================
# Symphix Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI / LLM ---
# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key

# --- Web Search (Research Agent) ---
# Tavily — Free 1000 searches/mo: https://app.tavily.com
TAVILY_API_KEY=tvly-your-tavily-key

# --- Email (Email Agent) ---
# Resend — Free 100 emails/day: https://resend.com
RESEND_API_KEY=re_your_resend_key
# Optional: Custom from address (requires verified domain in Resend)
# RESEND_FROM_EMAIL=Symphix <noreply@yourdomain.com>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
